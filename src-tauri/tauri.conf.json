{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MiniMD",
  "version": "0.1.0",
  "identifier": "com.minimd.mdeditor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MiniMD",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "MiniMD",
    "copyright": "",
    "category": "Productivity",
    "shortDescription": "A lightweight Markdown editor",
    "longDescription": "MiniMD is a lightweight Markdown editor built with Tauri and React.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "windows": {
      "webviewInstallMode": {
        "silent": true,
        "type": "downloadBootstrapper"
      },
      "wix": {
        "language": "zh-CN",
        "upgradeCode": "E3C1B3B0-7D3B-4F6E-8B9A-1A2B3C4D5E6F"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null,
      "exceptionDomain": null,
      "frameworks": [],
      "providerShortName": null
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-0.1"
        ],
        "section": "editors"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "cli": {
      "args": [
        {
          "name": "file",
          "description": "Markdown file to open",
          "index": 1,
          "takesValue": true
        }
      ]
    }
  }
}
